[Unit]
Description=bot-metrics — Telegram bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bot
Group=bot
WorkingDirectory=/opt/bot-metrics/repo
EnvironmentFile=/opt/bot-metrics/.env
ExecStart=/opt/bot-metrics/venv/bin/python -u /opt/bot-metrics/repo/bot.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
