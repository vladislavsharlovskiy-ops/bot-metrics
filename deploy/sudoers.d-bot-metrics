# bot-metrics: разрешаем service-юзеру bot перезапускать свои сервисы
# и запускать deploy.sh без пароля. Никаких других sudo-команд.
bot ALL=(root) NOPASSWD: /opt/bot-metrics/bin/deploy.sh
bot ALL=(root) NOPASSWD: /bin/systemctl restart bot-metrics-bot
bot ALL=(root) NOPASSWD: /bin/systemctl restart bot-metrics-web
bot ALL=(root) NOPASSWD: /bin/systemctl restart bot-metrics-deploy
